# Clave de API de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token de verificación del webhook (cadena cualquiera, larga, que TÚ inventás
# y configurás también en Meta Developers al registrar el webhook)
META_VERIFY_TOKEN=cambiame-por-una-cadena-aleatoria

# WhatsApp Cloud API ---------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=EAAG...

# Instagram Messaging --------------------------------------------------------
INSTAGRAM_ACCOUNT_ID=000000000000000
INSTAGRAM_ACCESS_TOKEN=EAAG...

# Puerto del servidor
PORT=8000

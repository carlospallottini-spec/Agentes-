# Clave de API de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Ruta al archivo credentials.json descargado desde Google Cloud Console
# (OAuth 2.0 Client ID, tipo Desktop)
GMAIL_CREDENTIALS_FILE=./credentials/credentials.json

# Ruta donde se guardará el token OAuth tras la primera autorización
GMAIL_TOKEN_FILE=./credentials/token.json

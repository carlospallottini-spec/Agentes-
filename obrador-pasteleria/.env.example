# Clave de API de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token de verificación del webhook (cadena cualquiera, larga, que TÚ inventás
# y configurás también en Meta Developers al registrar el webhook)
META_VERIFY_TOKEN=cambiame-por-una-cadena-aleatoria

# WhatsApp Cloud API ---------------------------------------------------------
# ID del número de WhatsApp Business (Meta for Developers → tu app → WhatsApp → API Setup)
WHATSAPP_PHONE_NUMBER_ID=000000000000000
# Access token de System User con permisos whatsapp_business_messaging
WHATSAPP_ACCESS_TOKEN=EAAG...

# Instagram Messaging --------------------------------------------------------
# ID de la cuenta de Instagram Business
INSTAGRAM_ACCOUNT_ID=000000000000000
# Page Access Token de la página de Facebook vinculada a esa cuenta de IG
INSTAGRAM_ACCESS_TOKEN=EAAG...

# Puerto del servidor (Railway/Render lo inyectan; por defecto 8000 en local)
PORT=8000
